# Test environment - copy to application-test.yaml and fill in real values
spring:
  sql:
    init:
      mode: never
  jpa:
    hibernate:
      ddl-auto: validate
  data:
    redis:
      host: 127.0.0.1
      port: 6379
      database: 1
      password: <your-redis-password>
      timeout: 10s
      lettuce:
        pool:
          min-idle: 0
          max-idle: 8
          max-active: 8
          max-wait: -1ms
  # Database - PostgreSQL (dynamic-datasource, master/slave)
  datasource:
    dynamic:
      datasource:
        user_master:
          driver-class-name: org.postgresql.Driver
          url: jdbc:postgresql://localhost:5432/archsmith_user_test
          username: <your-db-username>
          password: <your-db-password>
        user_slave:
          driver-class-name: org.postgresql.Driver
          url: jdbc:postgresql://localhost:5432/archsmith_user_test
          username: <your-db-username>
          password: <your-db-password>
        task_master:
          driver-class-name: org.postgresql.Driver
          url: jdbc:postgresql://localhost:5432/archsmith_task_test
          username: <your-db-username>
          password: <your-db-password>
        task_slave:
          driver-class-name: org.postgresql.Driver
          url: jdbc:postgresql://localhost:5432/archsmith_task_test
          username: <your-db-username>
          password: <your-db-password>

# OpenTelemetry (tracing configured via OTel SDK env vars: OTEL_EXPORTER_OTLP_ENDPOINT, OTEL_TRACES_SAMPLER_ARG)
management:
  otlp:
    metrics:
      export:
        url: http://localhost:4318/v1/metrics

arch-smith:
  flyway:
    enabled: true
  jwt:
    secret: <your-jwt-secret>
    expire-seconds: 86400
  captcha:
    enabled: true
