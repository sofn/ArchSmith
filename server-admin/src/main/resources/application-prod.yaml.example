# Production environment - copy to application-prod.yaml and fill in real values
spring:
  sql:
    init:
      mode: never
  jpa:
    hibernate:
      ddl-auto: validate
  data:
    redis:
      host: <your-redis-host>
      port: 6379
      database: 0
      password: ${REDIS_PASSWORD}
      timeout: 10s
      lettuce:
        pool:
          min-idle: 5
          max-idle: 20
          max-active: 50
          max-wait: -1ms
  # Database - PostgreSQL (dynamic-datasource, master/slave)
  datasource:
    dynamic:
      datasource:
        user_master:
          driver-class-name: org.postgresql.Driver
          url: jdbc:postgresql://<db-master-host>:5432/archsmith_user?sslmode=require
          username: ${DB_USERNAME}
          password: ${DB_PASSWORD}
        user_slave:
          driver-class-name: org.postgresql.Driver
          url: jdbc:postgresql://<db-slave-host>:5432/archsmith_user?sslmode=require
          username: ${DB_USERNAME}
          password: ${DB_PASSWORD}
        task_master:
          driver-class-name: org.postgresql.Driver
          url: jdbc:postgresql://<db-master-host>:5432/archsmith_task?sslmode=require
          username: ${DB_USERNAME}
          password: ${DB_PASSWORD}
        task_slave:
          driver-class-name: org.postgresql.Driver
          url: jdbc:postgresql://<db-slave-host>:5432/archsmith_task?sslmode=require
          username: ${DB_USERNAME}
          password: ${DB_PASSWORD}

# OpenTelemetry (tracing configured via OTel SDK env vars: OTEL_EXPORTER_OTLP_ENDPOINT, OTEL_TRACES_SAMPLER_ARG)
management:
  otlp:
    metrics:
      export:
        url: ${OTEL_EXPORTER_OTLP_ENDPOINT:http://localhost:4318/v1/metrics}

arch-smith:
  flyway:
    enabled: true
  jwt:
    secret: ${JWT_SECRET}
    expire-seconds: 3600
  captcha:
    enabled: true
