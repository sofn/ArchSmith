# Production environment - copy to application-prod.yaml and fill in real values
spring:
  sql:
    init:
      mode: never
  jpa:
    hibernate:
      ddl-auto: validate
  data:
    redis:
      host: <your-redis-host>
      port: 6379
      database: 0
      password: ${REDIS_PASSWORD}
      timeout: 10s
      lettuce:
        pool:
          min-idle: 5
          max-idle: 20
          max-active: 50
          max-wait: -1ms
  # Database - PostgreSQL (dynamic-datasource, master/slave)
  datasource:
    dynamic:
      datasource:
        user_master:
          driver-class-name: org.postgresql.Driver
          url: jdbc:postgresql://<db-master-host>:5432/archsmith_user?sslmode=require
          username: ${DB_USERNAME}
          password: ${DB_PASSWORD}
        user_slave:
          driver-class-name: org.postgresql.Driver
          url: jdbc:postgresql://<db-slave-host>:5432/archsmith_user?sslmode=require
          username: ${DB_USERNAME}
          password: ${DB_PASSWORD}
        task_master:
          driver-class-name: org.postgresql.Driver
          url: jdbc:postgresql://<db-master-host>:5432/archsmith_task?sslmode=require
          username: ${DB_USERNAME}
          password: ${DB_PASSWORD}
        task_slave:
          driver-class-name: org.postgresql.Driver
          url: jdbc:postgresql://<db-slave-host>:5432/archsmith_task?sslmode=require
          username: ${DB_USERNAME}
          password: ${DB_PASSWORD}

# OpenTelemetry (tracing configured via OTel SDK env vars: OTEL_EXPORTER_OTLP_ENDPOINT, OTEL_TRACES_SAMPLER_ARG)
management:
  otlp:
    metrics:
      export:
        url: ${OTEL_EXPORTER_OTLP_ENDPOINT:http://localhost:4318/v1/metrics}

arch-smith:
  # RSA 私钥（生产环境必须通过环境变量 ARCH_SMITH_RSA_PRIVATE_KEY 注入）
  rsa-private-key: ${ARCH_SMITH_RSA_PRIVATE_KEY}
  flyway:
    enabled: true
  jwt:
    secret: ${JWT_SECRET}
    expire-seconds: 3600
  captcha:
    enabled: true
  # 登录安全策略（防暴力破解）
  login:
    max-attempts: 5
    lockout-seconds: 600
  # CORS 白名单（生产环境必须配置具体域名）
  cors:
    allowed-origins:
      - https://admin.archsmith.example.com
      - https://archsmith.example.com
    allow-credentials: true
  # 文件上传安全策略
  file-storage:
    max-file-size: 10485760  # 10MB
    allowed-extensions:
      - jpg
      - jpeg
      - png
      - gif
      - webp
      - pdf
      - doc
      - docx
      - xls
      - xlsx
      - txt
      - csv
